{
  "name": "cv-generator",
  "version": "1.0.0",
  "description": "Gerador de CV online — multi-step, preview em tempo real e exportação para PDF",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "deploy": "vite build && gh-pages -d dist --dotfiles -u \"rdonkdev <rdonkdev@users.noreply.github.com>\" -m \"deploy: GitHub Pages build\""
  },
  "dependencies": {
    "pinia": "^2.2.6",
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@vite-pwa/assets-generator": "^1.0.2",
    "@vitejs/plugin-vue": "^5.2.1",
    "autoprefixer": "^10.4.20",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.9.2",
    "eslint-plugin-vuejs-accessibility": "^2.5.0",
    "gh-pages": "^6.3.0",
    "globals": "^17.7.0",
    "postcss": "^8.4.49",
    "prettier": "^3.8.5",
    "tailwindcss": "^3.4.17",
    "vite": "^6.0.5",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.9"
  }
